{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "NODE_ENV": "development",
        "API_BASE_URL": "http://10.0.2.2:8000/oneFourSeven/",
        "DEBUG_LOGGING": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://snookerapp.up.railway.app/oneFourSeven/",
        "DEBUG_LOGGING": "false",
        "ANDROID_PACKAGE": "com.avielpahima.maxbreaksnooker.preview",
        "APP_VARIANT": "preview"
      }
    },
    "beta": {
      "distribution": "internal",
      "channel": "beta",
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://snookerapp.up.railway.app/oneFourSeven/",
        "EXPO_PUBLIC_FORCE_DEBUG_LOGGING": "true"
      },
      "android": {
        "buildType": "apk",
        "autoIncrement": true,
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://snookerapp.up.railway.app/oneFourSeven/",
        "DEBUG_LOGGING": "false",
        "ENABLE_SSL_PINNING": "true"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest"
      },
      "android": {
        "ndk": "28.2.13676358"
      }
    },
    "production-apk": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://snookerapp.up.railway.app/oneFourSeven/",
        "DEBUG_LOGGING": "true",
        "ENABLE_SSL_PINNING": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "avielpahima@gmail.com",
        "ascAppId": "6762826909",
        "appleTeamId": "HPNS9888XR"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
